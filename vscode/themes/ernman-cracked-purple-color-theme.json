{
  "$schema": "vscode://schemas/color-theme",
  "name": "Ernman Cracked Purple",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#af87ff",
    "foreground": "#ffffff",
    "descriptionForeground": "#6c6c6c",
    "errorForeground": "#f38ba8",
    "icon.foreground": "#d7d7ff",
    "badge.background": "#af87ff",
    "badge.foreground": "#1f1f1f",
    "progressBar.background": "#af87ff",
    "activityBar.background": "#1f1f1f",
    "activityBar.foreground": "#d7d7ff",
    "activityBar.inactiveForeground": "#6c6c6c",
    "activityBar.activeBorder": "#af87ff",
    "sideBar.background": "#1e1e2e",
    "sideBar.foreground": "#d7d7ff",
    "sideBarTitle.foreground": "#d7d7ff",
    "sideBarSectionHeader.background": "#2a2440",
    "titleBar.activeBackground": "#1f1f1f",
    "titleBar.activeForeground": "#d7d7ff",
    "statusBar.background": "#2a2440",
    "statusBar.foreground": "#d7d7ff",
    "statusBar.noFolderBackground": "#2a2440",
    "statusBar.debuggingBackground": "#5f00af",
    "tab.activeBackground": "#1f1f1f",
    "tab.inactiveBackground": "#2a2440",
    "tab.activeBorderTop": "#af87ff",
    "panel.background": "#1e1e2e",
    "panel.border": "#302d41",
    "list.activeSelectionBackground": "#3a2a5a",
    "list.activeSelectionForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#2a2440",
    "list.hoverBackground": "#2a2440",
    "scrollbarSlider.background": "#302d41",
    "scrollbarSlider.hoverBackground": "#af87ff33",
    "scrollbarSlider.activeBackground": "#af87ff66",
    "input.background": "#2a2440",
    "input.foreground": "#d7d7ff",
    "input.border": "#302d41",
    "dropdown.background": "#2a2440",
    "dropdown.border": "#302d41",
    "quickInput.background": "#2a2440",
    "quickInput.foreground": "#d7d7ff",
    "quickInputList.focusBackground": "#3a2a5a",
    "quickInputList.focusForeground": "#ffffff",
    "quickInputTitle.background": "#1f1f1f",
    "menu.background": "#2a2440",
    "menu.foreground": "#d7d7ff",
    "menu.selectionBackground": "#3a2a5a",
    "editor.background": "#1f1f1f",
    "editor.foreground": "#ffffff",
    "editorLineNumber.foreground": "#6c6c6c",
    "editorLineNumber.activeForeground": "#d787ff",
    "editorGutter.background": "#1f1f1f",
    "editor.lineHighlightBackground": "#2a2440",
    "editor.selectionBackground": "#3a2a5a",
    "editor.inactiveSelectionBackground": "#3a2a5a66",
    "editor.selectionHighlightBackground": "#3a2a5a66",
    "editor.wordHighlightBackground": "#302d411a",
    "editor.wordHighlightStrongBackground": "#302d4133",
    "editorCursor.foreground": "#d787ff",
    "editorWhitespace.foreground": "#6c6c6c",
    "editorIndentGuide.background1": "#302d41",
    "editorIndentGuide.activeBackground1": "#af87ff",
    "editor.findMatchBackground": "#af87ff66",
    "editor.findMatchForeground": "#1f1f1f",
    "editor.findMatchHighlightBackground": "#d787ff33",
    "editor.findRangeHighlightBackground": "#302d411a",
    "editor.findMatchBorder": "#af87ff",
    "editor.findMatchHighlightBorder": "#d787ff",
    "editorBracketMatch.background": "#3a2a5a",
    "editorBracketMatch.border": "#d787ff",
    "editorOverviewRuler.findMatchForeground": "#af87ff66",
    "minimap.findMatchHighlight": "#af87ff66",
    "minimap.selectionHighlight": "#3a2a5a66",
    "editorWidget.background": "#2a2440",
    "editorWidget.foreground": "#d7d7ff",
    "editorWidget.border": "#302d41",
    "editorHoverWidget.background": "#2a2440",
    "editorSuggestWidget.background": "#2a2440",
    "editorSuggestWidget.foreground": "#d7d7ff",
    "editorSuggestWidget.border": "#302d41",
    "editorSuggestWidget.selectedBackground": "#5f00af",
    "editorSuggestWidget.selectedForeground": "#ffffff",
    "editorSuggestWidget.highlightForeground": "#d787ff",
    "peekViewEditor.background": "#1f1f1f",
    "peekViewResult.background": "#2a2440",
    "peekViewResult.selectionBackground": "#3a2a5a",
    "peekViewTitle.background": "#1f1f1f",
    "terminal.background": "#1f1f1f",
    "terminal.foreground": "#d7d7ff",
    "terminal.selectionBackground": "#3a2a5a66",
    "terminal.findMatchBackground": "#af87ff66",
    "terminal.findMatchBorder": "#af87ff",
    "terminal.findMatchHighlightBackground": "#d787ff33",
    "terminal.findMatchHighlightBorder": "#d787ff",
    "terminalCursor.foreground": "#d787ff",
    "terminalCursor.background": "#1f1f1f",
    "terminal.ansiBlack": "#1f1f1f",
    "terminal.ansiRed": "#f38ba8",
    "terminal.ansiGreen": "#a6e3a1",
    "terminal.ansiYellow": "#f9e2af",
    "terminal.ansiBlue": "#74c7ec",
    "terminal.ansiMagenta": "#aa90cf",
    "terminal.ansiCyan": "#94e2d5",
    "terminal.ansiWhite": "#d7d7ff",
    "terminal.ansiBrightBlack": "#6c6c6c",
    "terminal.ansiBrightRed": "#f38ba8",
    "terminal.ansiBrightGreen": "#a6e3a1",
    "terminal.ansiBrightYellow": "#f9e2af",
    "terminal.ansiBrightBlue": "#74c7ec",
    "terminal.ansiBrightMagenta": "#d787ff",
    "terminal.ansiBrightCyan": "#94e2d5",
    "terminal.ansiBrightWhite": "#ffffff",
    "editorGutter.addedBackground": "#a6e3a126",
    "editorGutter.modifiedBackground": "#fab38726",
    "editorGutter.deletedBackground": "#f38ba826",
    "diffEditor.insertedTextBackground": "#a6e3a126",
    "diffEditor.removedTextBackground": "#f38ba826",
    "diffEditor.insertedLineBackground": "#a6e3a11a",
    "diffEditor.removedLineBackground": "#f38ba81a",
    "diffEditor.insertedTextBorder": "#a6e3a1",
    "diffEditor.removedTextBorder": "#f38ba8",
    "gitDecoration.addedResourceForeground": "#a6e3a1",
    "gitDecoration.modifiedResourceForeground": "#fab387",
    "gitDecoration.deletedResourceForeground": "#f38ba8",
    "gitDecoration.untrackedResourceForeground": "#94e2d5",
    "gitDecoration.ignoredResourceForeground": "#6c6c6c",
    "gitDecoration.conflictingResourceForeground": "#f9e2af",
    "breadcrumb.foreground": "#6c6c6c",
    "breadcrumb.focusForeground": "#d7d7ff",
    "breadcrumb.activeSelectionForeground": "#af87ff",
    "editorGroupHeader.tabsBackground": "#1e1e2e",
    "tab.hoverBackground": "#2a2440",
    "tab.unfocusedHoverBackground": "#2a2440",
    "sideBar.dropBackground": "#3a2a5a80",
    "tree.indentGuidesStroke": "#302d41",
    "editorBracketHighlight.foreground1": "#74c7ec",
    "editorBracketHighlight.foreground2": "#fab387",
    "editorBracketHighlight.foreground3": "#a6e3a1",
    "editorBracketHighlight.foreground4": "#f38ba8",
    "editorBracketHighlight.foreground5": "#94e2d5",
    "editorBracketHighlight.foreground6": "#aa90cf"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#817e7e"
      }
    },
    {
      "name": "Markdown prose",
      "scope": [
        "text.html.markdown",
        "meta.paragraph.markdown",
        "markup.paragraph.markdown"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "name": "Numbers and booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#faaa78"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#b452ff"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#91d7e3"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#6e6a86"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.constant.handlebars",
        "source.powershell variable.other.member",
        "entity.name.operator.custom-literal",
        "meta.function-call",
        "entity.name.function.call",
        "support.function.builtin",
        "support.function.magic",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#7dcfff"
      }
    },
    {
      "name": "Types declaration and references",
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "entity.name.class",
        "storage.type.numeric.go",
        "storage.type.byte.go",
        "storage.type.boolean.go",
        "storage.type.string.go",
        "storage.type.uintptr.go",
        "storage.type.error.go",
        "storage.type.rune.go",
        "storage.type.cs",
        "storage.type.generic.cs",
        "storage.type.modifier.cs",
        "storage.type.variable.cs",
        "storage.type.generic.java",
        "storage.type.java",
        "storage.type.object.array.java",
        "storage.type.primitive.array.java",
        "storage.type.primitive.java",
        "storage.type.token.java",
        "storage.type.groovy",
        "storage.type.parameters.groovy",
        "storage.type.generic.groovy",
        "storage.type.object.array.groovy",
        "storage.type.primitive.array.groovy",
        "storage.type.primitive.groovy"
      ],
      "settings": {
        "foreground": "#8aadf4"
      }
    },
    {
      "name": "Decorators and attributes",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "entity.other.attribute",
        "entity.name.tag.attribute.tsx",
        "meta.annotation",
        "storage.type.annotation.java",
        "storage.type.annotation.groovy"
      ],
      "settings": {
        "foreground": "#d787ff"
      }
    },
    {
      "name": "Types declaration and references, TS grammar specific",
      "scope": [
        "meta.type.cast.expr",
        "meta.type.new.expr",
        "support.constant.math",
        "support.constant.dom",
        "support.constant.json",
        "entity.other.inherited-class",
        "punctuation.separator.namespace.ruby"
      ],
      "settings": {
        "foreground": "#8aadf4"
      }
    },
    {
      "name": "Control flow and special keywords",
      "scope": [
        "keyword.control",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.trycatch",
        "keyword.control.exception",
        "keyword.control.c",
        "keyword.control.cpp",
        "source.cpp keyword.operator.new",
        "keyword.operator.delete",
        "keyword.other.using",
        "keyword.other.directive.using",
        "keyword.other.operator",
        "entity.name.operator"
      ],
      "settings": {
        "foreground": "#c6a0f6"
      }
    },
    {
      "name": "Broad keyword fallback",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.package.go",
        "keyword.import.go",
        "keyword.function.go",
        "keyword.type.go",
        "keyword.struct.go",
        "keyword.interface.go",
        "keyword.map.go",
        "keyword.chan.go",
        "keyword.var.go",
        "keyword.const.go"
      ],
      "settings": {
        "foreground": "#c6a0f6"
      }
    },
    {
      "name": "Declaration and modifier keywords",
      "scope": [
        "keyword.declaration",
        "storage.modifier",
        "storage.type.function",
        "storage.type.class",
        "storage.type.struct",
        "storage.type.enum",
        "storage.type.interface",
        "storage.type.impl",
        "storage.type.trait",
        "storage.type.let",
        "storage.type.const",
        "storage.type.var",
        "storage.modifier.c",
        "storage.modifier.cpp",
        "storage.modifier.rust",
        "storage.type.function.python",
        "storage.type.class.python",
        "storage.type.function.arrow.ts",
        "storage.type.class.ts",
        "storage.type.interface.ts",
        "storage.type.enum.ts",
        "storage.type.function.rust",
        "storage.type.struct.rust",
        "storage.type.enum.rust",
        "storage.type.trait.rust",
        "storage.type.impl.rust",
        "storage.type.function.go",
        "storage.type.interface.go",
        "storage.type.struct.go",
        "storage.type.map.go",
        "storage.type.chan.go"
      ],
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "name": "Storage type fallback",
      "scope": [
        "storage.type",
        "storage.type.built-in",
        "storage.type.primitive",
        "storage.type.c",
        "storage.type.cpp",
        "storage.type.lua",
        "storage.type.sql"
      ],
      "settings": {
        "foreground": "#8aadf4"
      }
    },
    {
      "name": "Variable and parameter name",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#d7d7ff"
      }
    },
    {
      "name": "Struct and object members",
      "scope": [
        "variable.other.member",
        "variable.other.object.property",
        "variable.other.property",
        "meta.member.access",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f5c2e7"
      }
    },
    {
      "name": "Constants and enums",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Object and data-format keys",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name.json",
        "entity.name.tag.yaml",
        "keyword.key.toml",
        "meta.tag.key.toml",
        "entity.name.tag.toml",
        "entity.name.table.toml",
        "entity.name.table.array.toml",
        "variable.other.readwrite.hcl",
        "entity.name.label.hcl",
        "entity.name.section.hcl"
      ],
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "name": "CSS property value",
      "scope": [
        "support.constant.property-value",
        "support.constant.font-name",
        "support.constant.media-type",
        "support.constant.media",
        "constant.other.color.rgb-value",
        "constant.other.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "name": "Regular expression groups",
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.group.assertion.regexp",
        "punctuation.definition.character-class.regexp",
        "punctuation.character.set.begin.regexp",
        "punctuation.character.set.end.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Regular expression characters",
      "scope": [
        "constant.character.character-class.regexp",
        "constant.other.character-class.set.regexp",
        "constant.other.character-class.regexp",
        "constant.character.set.regexp"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Regular expression operators",
      "scope": [
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Regular expression quantifiers",
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Character constants and options",
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Escape characters",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "keyword.other.sql",
        "keyword.other.create.sql",
        "keyword.other.data-integrity.sql"
      ],
      "settings": {
        "foreground": "#c6a0f6"
      }
    },
    {
      "name": "Bash builtins and keywords",
      "scope": [
        "support.function.builtin.shell",
        "entity.name.command.shell",
        "keyword.control.shell",
        "keyword.operator.assignment.compound.bash"
      ],
      "settings": {
        "foreground": "#c6a0f6"
      }
    },
    {
      "name": "Lua keywords",
      "scope": [
        "keyword.control.lua",
        "keyword.local.lua",
        "constant.language.lua"
      ],
      "settings": {
        "foreground": "#c6a0f6"
      }
    },
    {
      "name": "C/C++ preprocessor",
      "scope": [
        "keyword.control.directive",
        "meta.preprocessor",
        "punctuation.definition.directive"
      ],
      "settings": {
        "foreground": "#d787ff"
      }
    },
    {
      "name": "Language constants",
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.boolean",
        "constant.language.nil",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#faaa78"
      }
    },
    {
      "name": "Labels",
      "scope": "entity.name.label",
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "name": "Plain text files",
      "scope": [
        "text.plain"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Markdown headings and emphasis",
      "scope": [
        "markup.heading.markdown",
        "punctuation.definition.heading.markdown",
        "markup.bold.markdown",
        "punctuation.definition.bold.markdown",
        "markup.italic.markdown",
        "punctuation.definition.italic.markdown",
        "markup.underline",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#d787ff"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#8aadf4",
    "enum": "#8aadf4",
    "interface": "#8aadf4",
    "type": "#8aadf4",
    "typeParameter": "#b7bdf8",
    "function": "#7dcfff",
    "method": "#7dcfff",
    "namespace": "#8aadf4",
    "decorator": "#d787ff",
    "operator": "#91d7e3",
    "parameter": "#f5c2e7",
    "variable": "#d7d7ff",
    "property": "#f38ba8",
    "enumMember": "#f9e2af",
    "variable.readonly": "#f9e2af",
    "property.readonly": "#f9e2af",
    "customLiteral": "#f9e2af",
    "macro": "#f9e2af",
    "keyword": "#c6a0f6",
    "newOperator": "#c6a0f6",
    "selfKeyword": "#c6a0f6",
    "selfTypeKeyword": "#c6a0f6",
    "builtinType": "#8aadf4",
    "formatSpecifier": "#91d7e3",
    "lifetime": "#d787ff",
    "label": "#f38ba8",
    "unresolvedReference": "#f38ba8",
    "string": "#a6e3a1",
    "stringLiteral": "#a6e3a1",
    "number": "#fab387",
    "numberLiteral": "#fab387",
    "regexp": "#f9e2af",
    "comment": "#6c6c6c"
  }
}
